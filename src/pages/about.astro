---
import BaseLayout from '../layouts/BaseLayout.astro';
import HostMascot from '../components/HostMascot.astro';
import { getCollection } from 'astro:content';
const videos = await getCollection('videos', ({ data }) => !data.draft);
---

<BaseLayout
  title="채널 소개"
  description="VIP(Virtual in Playing)는 버츄얼 호스트 로지가 게임을 영상처럼 소개하는 채널입니다."
>
  <div style="max-width:760px;margin:0 auto">
    <div style="display:flex;gap:20px;align-items:center;margin:1rem 0 2rem;flex-wrap:wrap">
      <span
        class="ch-ava"
        style="width:112px;height:112px;box-shadow:0 10px 30px -8px rgba(87,230,195,.4)"
      >
        <HostMascot variant="avatar" />
      </span>
      <div>
        <h1 style="margin:0 0 .3rem;font-size:1.6rem">
          로지 <span style="color:var(--host)">◆</span>
        </h1>
        <div style="color:var(--text-muted)">
          VIP · 게임 소개 방송 · 영상 {videos.length}편
        </div>
      </div>
    </div>

    <div class="desc-box" style="font-size:.98rem;line-height:1.8">
      <p style="margin-top:0">
        안녕하세요, <b style="color:var(--host)">로지</b>예요! 🎀 저는 게임을
        <b>영상처럼 편하게</b> 소개하는 버츄얼 호스트예요. 긴 글 읽기 귀찮을 때, 제
        방송을 틀어놓고 자막만 따라오면 오늘 뭘 플레이할지 정해질 거예요.
      </p>
      <p>
        무과금으로 즐기는 무료 게임, 숨은 인디 명작, 내 취향을 찾아주는 게임 진단까지 —
        광고 카피가 아니라 <b>솔직한 감상</b>으로 골라드립니다.
      </p>
      <p style="margin-bottom:0;color:var(--text-muted);font-size:.86rem">
        ※ 이 채널의 영상은 실제 동영상 파일이 아니라, 자막·연출을 브라우저에서
        실시간 재생하는 "합성 방송" 포맷입니다. 데이터가 가볍고 로딩이 빨라요.
        (추후 음성 나레이션 지원 예정)
      </p>
    </div>

    <div class="section-title" style="margin-top:2rem"><span class="bar"></span> 코너</div>
    <ul style="color:var(--text-2);line-height:1.9;padding-left:1.2rem">
      <li><b>Free</b> — 지갑 안 열어도 되는 무료 게임</li>
      <li><b>Indie</b> — 입문자도 반하는 인디 명작</li>
      <li><b>Guide</b> — 내 게임 취향 찾기</li>
    </ul>
  </div>
</BaseLayout>
