---
// 전용 임베드 플레이어 — 헤더/푸터 없이 씬 플레이어(뉴스룸)만 렌더.
// VideoObject.embedUrl 대상. watch 페이지가 정본이라 여기는 noindex.
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import HostStage from '../../components/HostStage.astro';

export async function getStaticPaths() {
  const videos = await getCollection('videos', ({ data }) => !data.draft);
  return videos.map((video) => ({ params: { slug: video.id }, props: { video } }));
}

const { video } = Astro.props;
const { data } = video;
const scenes = data.scenes;
const playerId = video.id.replace(/[^a-z0-9]/gi, '');
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{data.title} · VIP</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={new URL(`/watch/${video.id}/`, Astro.site || 'https://virtual-in-playing.vercel.app').href} />
    <style is:global>
      html, body { margin: 0; padding: 0; background: #000; overflow: hidden; }
      body { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
      /* 임베드는 플레이어를 화면에 꽉 채운다 */
      .sp-shell { width: 100%; max-width: 100vw; }
      .sp-stage { border-radius: 0; }
    </style>
  </head>
  <body>
    <HostStage scenes={scenes} playerId={playerId} host={data.host} booth />
    <script src="/js/scene-player.js" defer is:inline></script>
  </body>
</html>
