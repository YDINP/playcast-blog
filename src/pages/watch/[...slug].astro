---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostStage from '../../components/HostStage.astro';
import HostMascot from '../../components/HostMascot.astro';
import VideoCard from '../../components/VideoCard.astro';
import CommentSection from '../../components/CommentSection.astro';
import {
  estimateSeconds,
  durationLabel,
  formatViews,
  timeAgo,
  posterOf,
} from '../../lib/video';

export async function getStaticPaths() {
  const videos = await getCollection('videos', ({ data }) => !data.draft);
  return videos.map((video) => ({
    params: { slug: video.id },
    props: { video, all: videos },
  }));
}

const { video, all } = Astro.props;
const { data } = video;
const scenes = data.scenes;
const playerId = video.id.replace(/[^a-z0-9]/gi, '');

// 트랜스크립트 챕터 시작시간(초)
function fmt(s: number) {
  const m = Math.floor(s / 60);
  return `${m}:${String(s % 60).padStart(2, '0')}`;
}
const chapters = scenes.map((s, i) => ({
  time: fmt(estimateSeconds(scenes.slice(0, i))),
  label: s.chapter || s.text,
}));

// 추천 (같은 카테고리 우선 → 나머지)
const related = all
  .filter((v) => v.id !== video.id)
  .sort((a, b) => {
    const sameA = a.data.category === data.category ? 0 : 1;
    const sameB = b.data.category === data.category ? 0 : 1;
    return sameA - sameB || +b.data.pubDate - +a.data.pubDate;
  })
  .slice(0, 6);

const dur = durationLabel(scenes, data.durationLabel);
const ogImage = new URL(
  `/open-graph/${video.id}.png`,
  Astro.site || 'https://playcast.vercel.app'
).href;
const poster = posterOf(data);
---

<BaseLayout title={data.title} description={data.description} image={poster ? new URL(poster, Astro.site).href : ogImage}>
  <div class="watch">
    <div class="watch-main">
      <HostStage scenes={scenes} playerId={playerId} host={data.host} />

      <h1>{data.title}</h1>
      <div class="watch-stats">
        <span>{formatViews(data.views)}</span>
        <span>·</span>
        <span>{data.pubDate.toLocaleDateString('ko-KR')}</span>
        <span>·</span>
        <span>{dur}</span>
        {data.tags.slice(0, 4).map((t) => <span style="color:var(--host)">#{t}</span>)}
      </div>

      <!-- 채널 행 -->
      <div class="ch-row">
        <span class="ch-ava"><HostMascot variant="avatar" /></span>
        <div>
          <div class="ch-name">로지 <span style="color:var(--host)">◆</span></div>
          <div class="ch-sub">VIP · 게임 소개 방송</div>
        </div>
        <button class="ch-subscribe" id="btn-sub" type="button">구독</button>
        <div class="ch-actions">
          <button class="ch-pill" id="btn-like" type="button" aria-label="좋아요">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10v11M2 13a2 2 0 012-2h3v10H4a2 2 0 01-2-2zM7 11l4-8a2 2 0 013 2l-1 5h5a2 2 0 012 2l-2 6a2 2 0 01-2 1H7"/></svg>
            <span id="like-n">{Math.max(1, Math.round(data.views * 0.04))}</span>
          </button>
          <button class="ch-pill" id="btn-share" type="button" aria-label="공유">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
            공유
          </button>
        </div>
      </div>

      <!-- 설명란 -->
      <div class="desc-box">
        <div class="meta">{formatViews(data.views)} · {timeAgo(data.pubDate)}</div>
        <div class="body clamp" id="desc-body">{data.description}</div>
        <button class="desc-toggle" id="desc-toggle" type="button">...더보기</button>
      </div>

      <!-- 트랜스크립트 (SEO/접근성: 대사 전문 정적 노출) -->
      <section class="transcript">
        <h2>대본 · 챕터</h2>
        <div class="tr-list" data-transcript={playerId}>
          {chapters.map((c) => (
            <button class="tr-item" type="button">
              <span class="t">{c.time}</span>
              <span>{c.label}</span>
            </button>
          ))}
        </div>
      </section>

      <CommentSection slug={video.id} source="vip" />
    </div>

    <aside class="watch-side">
      <h2>다음 추천</h2>
      <div class="side-list">
        {related.map((v) => <VideoCard video={v} variant="side" />)}
      </div>
    </aside>
  </div>

  <script is:inline slot="tail">
    (function () {
      var sub = document.getElementById('btn-sub');
      if (sub)
        sub.addEventListener('click', function () {
          var on = sub.classList.toggle('is-on');
          sub.textContent = on ? '구독중' : '구독';
        });
      var like = document.getElementById('btn-like');
      var likeN = document.getElementById('like-n');
      if (like && likeN)
        like.addEventListener('click', function () {
          var on = like.classList.toggle('is-on');
          likeN.textContent = String(
            parseInt(likeN.textContent, 10) + (on ? 1 : -1)
          );
        });
      var share = document.getElementById('btn-share');
      if (share)
        share.addEventListener('click', function () {
          if (navigator.share)
            navigator.share({ title: document.title, url: location.href }).catch(function () {});
          else {
            navigator.clipboard.writeText(location.href);
            share.lastChild.textContent = ' 복사됨';
          }
        });
      var body = document.getElementById('desc-body');
      var tg = document.getElementById('desc-toggle');
      if (body && tg)
        tg.addEventListener('click', function () {
          var clamped = body.classList.toggle('clamp');
          tg.textContent = clamped ? '...더보기' : '간략히';
        });
    })();
  </script>
</BaseLayout>
