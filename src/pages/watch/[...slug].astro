---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HostStage from '../../components/HostStage.astro';
import VideoCard from '../../components/VideoCard.astro';
import CommentSection from '../../components/CommentSection.astro';
import {
  estimateSeconds,
  durationLabel,
  formatViews,
  timeAgo,
  posterOf,
  stripEmphasis,
} from '../../lib/video';

export async function getStaticPaths() {
  const videos = await getCollection('videos', ({ data }) => !data.draft);
  return videos.map((video) => ({
    params: { slug: video.id },
    props: { video, all: videos },
  }));
}

const { video, all } = Astro.props;
const { data } = video;
const scenes = data.scenes;
const playerId = video.id.replace(/[^a-z0-9]/gi, '');

// 트랜스크립트 챕터 시작시간(초)
function fmt(s: number) {
  const m = Math.floor(s / 60);
  return `${m}:${String(s % 60).padStart(2, '0')}`;
}
const chapters = scenes.map((s, i) => ({
  time: fmt(estimateSeconds(scenes.slice(0, i))),
  label: s.chapter || stripEmphasis(s.text),
}));

// 추천 (같은 카테고리 우선 → 나머지)
const related = all
  .filter((v) => v.id !== video.id)
  .sort((a, b) => {
    const sameA = a.data.category === data.category ? 0 : 1;
    const sameB = b.data.category === data.category ? 0 : 1;
    return sameA - sameB || +b.data.pubDate - +a.data.pubDate;
  })
  .slice(0, 6);

const dur = durationLabel(scenes, data.durationLabel);
const site = Astro.site || new URL('https://virtual-in-playing.vercel.app');
const ogImage = new URL(`/open-graph/${video.id}.png`, site).href;
const poster = posterOf(data);
const imgAbs = poster ? new URL(poster, site).href : ogImage;
// 동영상(VideoObject) 썸네일은 Google 동영상 색인 호환을 위해 WebP 대신 JPG 사용.
// (WebP 썸네일은 "제공된 썸네일 URL 없음"으로 색인 실패하는 사례가 있음 → 동일 이미지 JPG 버전으로 대체)
const thumbForVideo = /\.webp$/i.test(imgAbs) ? imgAbs.replace(/\.webp$/i, '.jpg') : imgAbs;
// 전용 임베드 플레이어 URL (VideoObject 자격 강화: 실제 재생 가능한 player 페이지)
const embedUrl = new URL(`/embed/${video.id}/`, site).href;
const pageUrl = new URL(`/watch/${video.id}/`, site).href;
const totalSec = estimateSeconds(scenes);
const durationISO = `PT${Math.floor(totalSec / 60)}M${totalSec % 60}S`;
const published = data.pubDate.toISOString();
const modified = (data.updatedDate ?? data.pubDate).toISOString();

// 구조화 데이터: BlogPosting(대본 전문 기반 아티클) + VideoObject(영상 카드) + BreadcrumbList
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.description,
  image: [imgAbs],
  datePublished: published,
  dateModified: modified,
  timeRequired: durationISO,
  author: { '@type': 'Person', name: '로지', url: new URL('/about', site).href },
  publisher: {
    '@type': 'Organization',
    name: 'Virtual in Playing (VIP)',
    logo: { '@type': 'ImageObject', url: new URL('/og-default.png', site).href },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  articleSection: data.category,
  keywords: data.tags.join(', '),
  inLanguage: 'ko-KR',
  articleBody: scenes.map((s) => stripEmphasis(s.text)).join('\n'),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: site.href },
    { '@type': 'ListItem', position: 2, name: data.title, item: pageUrl },
  ],
};
// VideoObject — 실제 영상 파일(contentUrl/embedUrl)은 없으므로 생략(가짜 URL 금지).
// duration은 scene-player.js와 동일 공식으로 계산한 실제 재생시간(estimateSeconds)이라 허구가 아님.
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: data.title,
  description: data.description,
  thumbnailUrl: [thumbForVideo],
  embedUrl,
  uploadDate: published,
  ...(data.updatedDate ? { dateModified: modified } : {}),
  duration: durationISO,
  publisher: {
    '@type': 'Organization',
    name: 'Virtual in Playing',
    alternateName: 'VIP',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-default.png', site).href,
      width: 1200,
      height: 630,
    },
  },
};
// FAQPage — 인접 쿼리(출시일/시간/다운로드 등) 포획 + 리치결과. faq 있을 때만.
const faqSchema =
  data.faq && data.faq.length
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: data.faq.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={imgAbs}
  ogType="article"
  keywords={data.tags.join(', ')}
  article={{ published, modified, section: data.category, tags: data.tags }}
  schemas={[blogPostingSchema, videoSchema, breadcrumbSchema, faqSchema].filter(Boolean)}
>
  <article class="vw">
    <!-- 헤더: 제목·리드를 플레이어 위로 올려 "무엇에 관한 방송인지" 먼저 읽히게 -->
    <header class="vw-head">
      <div class="vw-chips">
        <span class="vw-chip is-cat">{data.category}</span>
        {data.tags.slice(0, 4).map((t) => <span class="vw-chip">#{t}</span>)}
      </div>
      <h1>{data.title}</h1>
      <p class="vw-lead">{data.description}</p>
      <div class="vw-meta">
        <span class="vw-n" data-vw-slug={video.id} data-vw-seed={data.views}>{formatViews(data.views)}</span>
        <span>·</span>
        <span>{timeAgo(data.pubDate)}</span>
        <span>·</span>
        <span>{dur}</span>
        <span>·</span>
        <span>{scenes.length}개 장면</span>
      </div>
    </header>

    <!-- 스테이지: 영상 프레임 + 우측 호스트 부스 -->
    <HostStage scenes={scenes} playerId={playerId} host={data.host} booth />

    <div class="vw-actions">
      <button class="ch-pill" id="btn-like" type="button" aria-label="좋아요">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10v11M2 13a2 2 0 012-2h3v10H4a2 2 0 01-2-2zM7 11l4-8a2 2 0 013 2l-1 5h5a2 2 0 012 2l-2 6a2 2 0 01-2 1H7"/></svg>
        <span id="like-n">{Math.max(1, Math.round(data.views * 0.04))}</span>
      </button>
      <button class="ch-pill" id="btn-share" type="button" aria-label="공유">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
        공유
      </button>
      <span class="spacer"></span>
      {
        data.imageCredit && (
          <span class="vw-credit">
            이미지:{' '}
            {data.imageCredit.url ? (
              <a href={data.imageCredit.url} target="_blank" rel="noopener nofollow">
                {data.imageCredit.text}
              </a>
            ) : (
              <span>{data.imageCredit.text}</span>
            )}
          </span>
        )
      }
    </div>

    <!-- 관련 상품(쿠팡 파트너스). coupang 프론트매터 있을 때만 -->
    {
      data.coupang && data.coupang.length > 0 && (
        <section class="vw-sec vw-shop">
          <h2>🎮 관련 상품</h2>
          <div class="vw-shop-row">
            {data.coupang.map((c) => (
              <a class="vw-shop-item" href={c.url} target="_blank" rel="noopener nofollow sponsored">
                <span class="vw-shop-t">{c.title}</span>
                {c.desc && <span class="vw-shop-d">{c.desc}</span>}
                <span class="vw-shop-go">쿠팡에서 보기 →</span>
              </a>
            ))}
          </div>
          <p class="vw-shop-note">쿠팡 파트너스 활동의 일환으로, 일정액의 수수료를 제공받을 수 있습니다.</p>
        </section>
      )
    }

    <!-- 자주 묻는 질문(FAQ). faq 프론트매터 있을 때만 · FAQPage 구조화데이터와 연동 -->
    {
      data.faq && data.faq.length > 0 && (
        <section class="vw-sec vw-faq">
          <h2>❓ 자주 묻는 질문</h2>
          <div class="vw-faq-list">
            {data.faq.map((f) => (
              <details class="vw-faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    <!-- 대본 = 챕터 타임라인 (클릭 시 해당 장면으로 점프 / SEO상 대사 전문 노출) -->
    <section class="vw-sec vw-script">
      <h2>대본 타임라인</h2>
      <div class="tr-list" data-transcript={playerId}>
        {chapters.map((c) => (
          <button class="tr-item" type="button">
            <span class="t">{c.time}</span>
            <span>{c.label}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- 추천: 우측 사이드바 대신 하단 풀폭 그리드 -->
    <section class="vw-sec">
      <h2>이어서 볼 방송</h2>
      <div class="pc-grid">
        {related.map((v) => <VideoCard video={v} />)}
      </div>
    </section>

    <section class="vw-sec">
      <CommentSection slug={video.id} source="vip" />
    </section>
  </article>

  <script is:inline slot="tail">
    (function () {
      var like = document.getElementById('btn-like');
      var likeN = document.getElementById('like-n');
      if (like && likeN)
        like.addEventListener('click', function () {
          var on = like.classList.toggle('is-on');
          likeN.textContent = String(
            parseInt(likeN.textContent, 10) + (on ? 1 : -1)
          );
        });
      var share = document.getElementById('btn-share');
      if (share)
        share.addEventListener('click', function () {
          if (navigator.share)
            navigator.share({ title: document.title, url: location.href }).catch(function () {});
          else {
            navigator.clipboard.writeText(location.href);
            share.lastChild.textContent = ' 복사됨';
          }
        });
    })();
  </script>
</BaseLayout>

<style>
  /* 관련 상품(쿠팡) — 다크 유튜브 톤. 클래스에 ad/banner 미포함(광고차단 회피) */
  .vw-shop-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .vw-shop-item {
    flex: 1 1 220px;
    display: flex; flex-direction: column; gap: 4px;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--card);
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }
  .vw-shop-item:hover { background: var(--card-hover); border-color: var(--host); transform: translateY(-2px); }
  .vw-shop-t { font-weight: 700; font-size: 0.96rem; color: var(--text); }
  .vw-shop-d { font-size: 0.8rem; color: var(--text-2); line-height: 1.4; }
  .vw-shop-go { font-size: 0.82rem; color: var(--host); font-weight: 600; margin-top: 2px; }
  .vw-shop-note { margin: 10px 0 0; font-size: 0.74rem; color: var(--text-muted); }
  /* FAQ 아코디언 */
  .vw-faq-list { display: flex; flex-direction: column; gap: 8px; }
  .vw-faq-item {
    border: 1px solid var(--border); border-radius: 10px; background: var(--card);
    padding: 0 14px; overflow: hidden;
  }
  .vw-faq-item summary {
    list-style: none; cursor: pointer; padding: 13px 0; font-weight: 700;
    font-size: 0.98rem; color: var(--text); position: relative; padding-right: 26px;
  }
  .vw-faq-item summary::-webkit-details-marker { display: none; }
  .vw-faq-item summary::after {
    content: '+'; position: absolute; right: 2px; top: 50%; transform: translateY(-50%);
    font-size: 1.2rem; color: var(--host); font-weight: 400; transition: transform 0.2s;
  }
  .vw-faq-item[open] summary::after { content: '−'; }
  .vw-faq-item p {
    margin: 0 0 14px; color: var(--text-2); font-size: 0.92rem; line-height: 1.6;
    word-break: keep-all;
  }
</style>
