---
// 호스트 리그: base.png(고정 베이스) 위에 얼굴 파츠(눈/눈썹/입/코)를 원본 크기로 얹음.
// vt.jpg 배치 참고. 애니메이션은 global.css .rig-* 참조.
//   - 깜빡임: 열린눈↔닫힌눈 opacity 스왑
//   - 립싱크: 말하는 중 닫힌입→열린입 스왑 + 개폐(.sp-host.is-talking)
//   - 표정: 씬 emotion → .sp-host.emo-* 가 눈/눈썹 변형
// 좌표: base(460x907) 기준 % (left, top, width). 크기=파츠 원본 비율.
const s = (l: number, t: number, w: number) => `left:${l}%;top:${t}%;width:${w}%`;
---

<div class="rig">
  <img class="rig-base" src="/host/base.png" alt="채널 호스트 로지" draggable="false" />

  <img class="rig-part rig-brow l" src="/host/face/brow_l.png" alt="" style={s(34.85, 23.8, 11.3)} />
  <img class="rig-part rig-brow r" src="/host/face/brow_r.png" alt="" style={s(53.85, 23.8, 11.3)} />

  <img class="rig-part rig-eye l" src="/host/face/eye_l.png" alt="" style={s(32.9, 26.9, 15.22)} />
  <img class="rig-part rig-eye r" src="/host/face/eye_r.png" alt="" style={s(51.9, 26.9, 15.22)} />
  <img class="rig-part rig-eyec l" src="/host/face/eyec_l.png" alt="" style={s(32.9, 28.1, 15.22)} />
  <img class="rig-part rig-eyec r" src="/host/face/eyec_r.png" alt="" style={s(51.9, 28.1, 15.22)} />

  <img class="rig-part rig-nose" src="/host/face/nose.png" alt="" style={s(48.26, 31.5, 3.48)} />

  <img class="rig-part rig-mouth" src="/host/face/mouth.png" alt="" style={s(45.32, 35.0, 9.35)} />
  <img class="rig-part rig-mouth-open" src="/host/face/mouth_open.png" alt="" style={s(45.32, 34.2, 9.35)} />
</div>
