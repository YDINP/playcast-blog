---
// 호스트 리그 = 새 캐릭터(final_assets). 2026-07-19:
//   1254² 정렬 풀 이미지 스택. base < 기본입(다문) < 표정 < 립싱크 < 블링크.
//   · base(입 없음) 위에 mouth-rest(다문 입) 항상 표시 → 말없을 때 입 유지
//   · 표정 emo-*  · 립싱크 data-viseme(아에이오우)  · 눈감기 is-blink
//   · 마우스추적: .rig-parts 래퍼 → rigLoop. transform-origin 하단(가슴)으로 상체만 움직임.
interface Props { emotions?: string[]; }
const _props = Astro.props as Props;
void _props;
// half = 개폐 리듬용 중간입(원작 애셋 blend, seam·드리프트 없음). 말할 때 개구↔반개 교대.
const VIS = ['a', 'e', 'i', 'o', 'u', 'half'];
---

<div class="rig">
  <div class="rig-parts">
    <img class="rig-base" src="/host/char2/base.webp" alt="채널 호스트" draggable="false" />
    <img class="rig-part rig-mouth-rest" src="/host/char2/mouth-rest.webp" alt="" draggable="false" />
    {/* 표정 변화 제거 — reference에 새로 생성한 애셋(base·blink·lip)만 사용 */}
    {VIS.map((v) => (
      <img class={`rig-part rig-lip l-${v}`} src={v === 'half' ? '/host/char2/lip-half.webp?v=3' : `/host/char2/lip-${v}.webp`} alt="" draggable="false" />
    ))}
    <img class="rig-part rig-blink" src="/host/char2/blink.webp" alt="" draggable="false" />
  </div>
</div>
