---
// vtt 파츠를 브라우저에서 레이어로 재조립 = 대략 Live2D 리그.
// 애니메이션(호흡/머리흔들림/깜빡임/립싱크)은 global.css .rig-* 참조.
// 좌표계: 컨테이너 100(가로) x 130(세로) units. left/width=가로%, top=세로%.
const T = (u: number) => ((u / 130) * 100).toFixed(2) + '%';
// [파일명, left%, topUnits, width%, extraClass]  — 뒤에 올수록 위 레이어
const parts: [string, number, number, number, string][] = [
  ['hair-back', 25, 10, 50, ''],
  ['face', 29, 23, 42, ''],
  ['bangs', 26, 11, 48, ''],
  ['brow-l', 37.8, 33.5, 12, 'rig-brow l'],
  ['brow-r', 50.2, 33.5, 12, 'rig-brow r'],
  ['eye-l', 38, 37, 12, 'rig-eye l'],
  ['eye-r', 50, 37, 12, 'rig-eye r'],
  ['mouth', 40, 50, 20, 'rig-mouth'],
  ['lock-r', 63, 27, 19, 'rig-lock'],
  ['lock-l', 18, 27, 19, 'rig-lock'],
  ['headset', 22.85, 8, 54.3, ''],
];
---

<div class="rig">
  <div class="rig-body">
    <img src="/host/parts/hoodie.png" alt="" style={`left:3%;top:${T(68)};width:94%`} />
    <img src="/host/parts/neck.png" alt="" style={`left:29.4%;top:${T(60)};width:41.2%`} />
  </div>
  <div class="rig-head">
    {
      parts.map(([name, left, top, width, cls]) => (
        <img
          src={`/host/parts/${name}.png`}
          alt=""
          class={cls}
          style={`left:${left}%;top:${T(top)};width:${width}%`}
        />
      ))
    }
  </div>
</div>
