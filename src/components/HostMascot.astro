---
// 채널 마스코트 "로지(Rosie)" — AI 일러스트(Live2D풍) 투명 PNG.
// variant: stage(반신 전체) / avatar(얼굴 크롭, 원형 아바타용)
interface Props {
  variant?: 'stage' | 'avatar';
  class?: string;
}
const { variant = 'stage', class: cls = '' } = Astro.props;
---

<img
  src="/host/rosie.png"
  alt="채널 호스트 로지"
  class:list={['pc-mascot', `pc-mascot-${variant}`, cls]}
  draggable="false"
  loading={variant === 'avatar' ? 'lazy' : 'eager'}
/>
