---
// 씬플레이어 스테이지 DOM 뼈대. scene-player.js가 .sp-data(JSON)를 읽어 구동.
import HostRig from './HostRig.astro';
import { parseEmphasis } from '../lib/video';

interface Scene {
  image?: string;
  text: string;
  emotion?: string;
  holdMs?: number;
  chapter?: string;
  voice?: string;
  card?: {
    kind?: 'stat' | 'title' | 'points';
    big?: string;
    label?: string;
    sub?: string;
    head?: string;
    items?: string[];
    pos?: string;
    size?: string;
  };
  point?: { x: number; y: number; emoji?: string; from?: [number, number]; label?: string };
}
interface Props {
  scenes: Scene[];
  playerId: string;
  host?: string;
  /** true면 호스트를 영상 밖 전용 부스 패널로 분리 (시청 페이지). false면 영상 내 오버레이 (홈 히어로). */
  booth?: boolean;
}
const { scenes, playerId, host = 'rosie', booth = false } = Astro.props;
const first = scenes[0] || { text: '' };
// 이 영상이 쓰는 표정만 로드 (파츠 8개 전부 얹으면 ~880KB)
const emotions = [...new Set(scenes.map((s) => s.emotion).filter(Boolean))] as string[];
---

<div class="sp-shell">
<div class="sp-stage is-paused" data-player={playerId} data-host={host}>
  <!-- 배경 크로스페이드 2레이어 (첫 씬 미리 노출) -->
  <div
    class:list={['sp-bg', 'sp-bg-a', 'is-on', { 'is-grad': !first.image }]}
    style={first.image ? `background-image:url("${first.image}")` : ''}
  >
  </div>
  <div class="sp-bg sp-bg-b"></div>

  <!-- 씬 타이포 카드(핵심 수치·문구 오버레이) — scene-player가 채운다 -->
  <div class="sp-card" aria-hidden="true"></div>

  <!-- 손가락 포인터(이미지 속 중요 지점 강조·이동) -->
  <div class="sp-pointer" aria-hidden="true"></div>

  <!-- 호스트 (파츠 재조립 리그) — 항상 영상 내 오버레이. booth=시청 페이지용 큰 우하단 캠. -->
  <div class:list={['sp-host', { 'sp-host--cam': booth }]}>
    <HostRig emotions={emotions} />
  </div>

  <!-- 자막 (첫 씬: 강조 세그먼트 SSR 렌더) -->
  <div class="sp-caption">
    <div class="box"><span class="sp-text">{parseEmphasis(first.text).map((seg) => (seg.em ? <span class="sp-em">{seg.s}</span> : seg.s))}</span><span class="cursor"></span></div>
  </div>

  <!-- 중앙 큰 재생 버튼 -->
  <div class="sp-bigplay">
    <button type="button" aria-label="재생">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
    </button>
  </div>

  <!-- 컨트롤바 -->
  <div class="sp-controls">
    <div class="sp-progress">
      <div class="sp-ticks"></div>
      <div class="sp-progress-fill"></div>
    </div>
    <div class="sp-btnrow">
      <button class="sp-play" type="button" aria-label="재생/일시정지"></button>
      <button class="sp-prev" type="button" aria-label="이전 장면">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zM20 6l-9 6 9 6z"></path></svg>
      </button>
      <button class="sp-next" type="button" aria-label="다음 장면">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM4 6l9 6-9 6z"></path></svg>
      </button>
      <button class="sp-replay" type="button" aria-label="처음부터">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path><path d="M3 3v5h5"></path></svg>
      </button>
      <span class="sp-time">0:00 / 0:00</span>
      <span class="sp-spacer"></span>
      <span class="sp-live">LIVE</span>
      <button class="sp-cap" type="button" aria-label="자막 위치 전환"></button>
      <button class="sp-mute" type="button" aria-label="음소거"></button>
    </div>
  </div>

  <!-- 씬 데이터 (인라인 JSON, 작은 페이로드) -->
  <script class="sp-data" type="application/json" set:html={JSON.stringify({ scenes })} />
</div>
</div>
