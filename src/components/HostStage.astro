---
// 씬플레이어 스테이지 DOM 뼈대. scene-player.js가 .sp-data(JSON)를 읽어 구동.
// booth=true(시청 페이지): 뉴스룸 레이아웃 — 좌상단 직사각형 영상 모니터 + 우측 앵커 호스트.
// booth=false(홈 히어로): 기존 풀프레임 배경 + 영상 내 오버레이 호스트.
import HostRig from './HostRig.astro';
import { parseEmphasis } from '../lib/video';

interface Scene {
  image?: string;
  text: string;
  emotion?: string;
  holdMs?: number;
  chapter?: string;
  voice?: string;
  card?: {
    kind?: 'stat' | 'title' | 'points';
    big?: string;
    label?: string;
    sub?: string;
    head?: string;
    items?: string[];
    pos?: string;
    size?: string;
  };
  point?: { x: number; y: number; emoji?: string; from?: [number, number]; label?: string };
}
interface Props {
  scenes: Scene[];
  playerId: string;
  host?: string;
  /** true면 뉴스룸 레이아웃(시청 페이지). false면 영상 내 오버레이(홈 히어로). */
  booth?: boolean;
}
const { scenes, playerId, host = 'rosie', booth = false } = Astro.props;
const first = scenes[0] || { text: '' };
const firstSegs = parseEmphasis(first.text);
const emotions = [...new Set(scenes.map((s) => s.emotion).filter(Boolean))] as string[];
---

{booth ? (
  <Fragment>
  <div class="sp-shell has-newsroom">
    <div class="sp-stage is-newsroom is-paused" data-player={playerId} data-host={host}>
      <!-- 뉴스룸 스튜디오 배경 -->
      <div class="sp-newsroom-bg" aria-hidden="true">
        <span class="nr-panel nr-panel-a"></span>
        <span class="nr-panel nr-panel-b"></span>
        <span class="nr-glow"></span>
      </div>

      <!-- LIVE 태그: 영상 모니터 '위'(바깥 상단)에 배치 — 영상 이미지를 가리지 않음.
           sp-screen은 overflow:hidden이라 모니터 밖으로 못 나가므로 형제로 분리한다. -->
      <span class="sp-screen-tag"><i></i>LIVE</span>

      <!-- 좌상단 직사각형 영상 모니터 -->
      <div class="sp-screen">
        <div
          class:list={['sp-bg', 'sp-bg-a', 'is-on', { 'is-grad': !first.image }]}
          style={first.image ? `background-image:url("${first.image}")` : ''}
        ></div>
        <div class="sp-bg sp-bg-b"></div>
        <div class="sp-card" aria-hidden="true"></div>
        <div class="sp-pointer" aria-hidden="true"></div>
      </div>

      <!-- 우측 앵커 호스트 -->
      <div class="sp-anchor" aria-hidden="true">
        <div class="sp-host sp-host--anchor">
          <HostRig emotions={emotions} />
        </div>
      </div>

      <!-- 앵커 데스크 + 오늘의 서울 날씨 뉴스 티커(무한 슬라이드) -->
      <div class="sp-desk" aria-hidden="true">
        <div class="sp-ticker">
          <div class="sp-ticker-track" data-weather>🌤️ 오늘의 서울 날씨를 불러오는 중…</div>
        </div>
        <span class="sp-desk-logo">VIP</span>
      </div>

      <!-- 뉴스 하단 자막(카이런) -->
      <div class="sp-caption sp-chyron">
        <span class="chyron-tag"><i class="chyron-dot"></i>로지</span>
        <div class="box"><span class="sp-text">{firstSegs.map((seg) => (seg.em ? <span class="sp-em">{seg.s}</span> : seg.s))}</span><span class="cursor"></span></div>
      </div>

      <div class="sp-bigplay">
        <button type="button" aria-label="재생">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
        </button>
      </div>

      <script class="sp-data" type="application/json" set:html={JSON.stringify({ scenes })} />
    </div>
    <div class="sp-controls">
      <div class="sp-progress">
        <div class="sp-ticks"></div>
        <div class="sp-progress-fill"></div>
      </div>
      <div class="sp-btnrow">
        <button class="sp-play" type="button" aria-label="재생/일시정지"></button>
        <button class="sp-prev" type="button" aria-label="이전 장면"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zM20 6l-9 6 9 6z"></path></svg></button>
        <button class="sp-next" type="button" aria-label="다음 장면"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM4 6l9 6-9 6z"></path></svg></button>
        <button class="sp-replay" type="button" aria-label="처음부터"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path><path d="M3 3v5h5"></path></svg></button>
        <span class="sp-time">0:00 / 0:00</span>
        <span class="sp-spacer"></span>
        <span class="sp-live">LIVE</span>
        <button class="sp-cap" type="button" aria-label="자막 위치 전환"></button>
        <button class="sp-mute" type="button" aria-label="음소거"></button>
        <button class="sp-fs" type="button" aria-label="전체화면"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9V5a1 1 0 0 1 1-1h4M20 9V5a1 1 0 0 0-1-1h-4M4 15v4a1 1 0 0 0 1 1h4M20 15v4a1 1 0 0 1-1 1h-4"/></svg></button>
      </div>
    </div>
  </div>

  <!-- 데스크 날씨 티커: 서울 실시간 날씨(open-meteo, 키 불필요) -->
  <script>
    const WMO: Record<number, string> = {
      0: '맑음', 1: '대체로 맑음', 2: '구름 조금', 3: '흐림', 45: '안개', 48: '서리안개',
      51: '약한 이슬비', 53: '이슬비', 55: '강한 이슬비', 56: '어는 이슬비', 57: '강한 어는 이슬비',
      61: '약한 비', 63: '비', 65: '강한 비', 66: '어는 비', 67: '강한 어는 비',
      71: '약한 눈', 73: '눈', 75: '강한 눈', 77: '싸락눈',
      80: '약한 소나기', 81: '소나기', 82: '강한 소나기', 85: '약한 눈소나기', 86: '눈소나기',
      95: '뇌우', 96: '뇌우·우박', 99: '강한 뇌우·우박',
    };
    const icon = (c: number) =>
      c === 0 ? '☀️' : c <= 2 ? '🌤️' : c === 3 ? '☁️' : c <= 48 ? '🌫️'
      : c <= 67 ? '🌧️' : c <= 77 ? '❄️' : c <= 86 ? '🌦️' : '⛈️';
    async function fillWeather() {
      const els = document.querySelectorAll<HTMLElement>('.sp-ticker-track[data-weather]');
      if (!els.length) return;
      try {
        const url =
          'https://api.open-meteo.com/v1/forecast?latitude=37.5665&longitude=126.978' +
          '&current=temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m' +
          '&daily=temperature_2m_max,temperature_2m_min,precipitation_probability_max&timezone=Asia%2FSeoul';
        const j = await (await fetch(url)).json();
        const c = j.current, d = j.daily;
        const now = new Date();
        const timeStr = now.toLocaleTimeString('ko-KR', { hour: 'numeric', minute: '2-digit' });
        const seg = [
          `📺 VIP 뉴스 · ${now.getMonth() + 1}월 ${now.getDate()}일 ${timeStr} 기준 서울 날씨`,
          `${icon(c.weather_code)} ${WMO[c.weather_code] ?? ''} ${Math.round(c.temperature_2m)}°`,
          `최고 ${Math.round(d.temperature_2m_max[0])}° / 최저 ${Math.round(d.temperature_2m_min[0])}°`,
          `강수확률 ${d.precipitation_probability_max?.[0] ?? 0}%`,
          `습도 ${c.relative_humidity_2m}%`,
          `바람 ${Math.round(c.wind_speed_10m)}m/s`,
        ].join(' · ') + ' · ';
        els.forEach((el) => {
          el.innerHTML = `<span>${seg}</span><span>${seg}</span>`; // 2회 반복 → 무한 루프 이음매 제거
          el.classList.add('is-ready');
        });
      } catch {
        els.forEach((el) => (el.textContent = '📺 VIP 뉴스 — 시청해 주셔서 감사합니다'));
      }
    }
    fillWeather();
    setInterval(fillWeather, 15 * 60 * 1000); // 15분마다 최신 날씨로 갱신
    document.addEventListener('visibilitychange', () => { if (!document.hidden) fillWeather(); }); // 탭 복귀 시 갱신
  </script>
  </Fragment>
) : (
  <div class="sp-shell">
    <div class="sp-stage is-paused" data-player={playerId} data-host={host}>
      <div
        class:list={['sp-bg', 'sp-bg-a', 'is-on', { 'is-grad': !first.image }]}
        style={first.image ? `background-image:url("${first.image}")` : ''}
      ></div>
      <div class="sp-bg sp-bg-b"></div>
      <div class="sp-card" aria-hidden="true"></div>
      <div class="sp-pointer" aria-hidden="true"></div>
      <div class="sp-host">
        <HostRig emotions={emotions} />
      </div>
      <div class="sp-caption">
        <div class="box"><span class="sp-text">{firstSegs.map((seg) => (seg.em ? <span class="sp-em">{seg.s}</span> : seg.s))}</span><span class="cursor"></span></div>
      </div>
      <div class="sp-bigplay">
        <button type="button" aria-label="재생">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
        </button>
      </div>
      <script class="sp-data" type="application/json" set:html={JSON.stringify({ scenes })} />
    </div>
    <div class="sp-controls">
      <div class="sp-progress">
        <div class="sp-ticks"></div>
        <div class="sp-progress-fill"></div>
      </div>
      <div class="sp-btnrow">
        <button class="sp-play" type="button" aria-label="재생/일시정지"></button>
        <button class="sp-prev" type="button" aria-label="이전 장면"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zM20 6l-9 6 9 6z"></path></svg></button>
        <button class="sp-next" type="button" aria-label="다음 장면"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM4 6l9 6-9 6z"></path></svg></button>
        <button class="sp-replay" type="button" aria-label="처음부터"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path><path d="M3 3v5h5"></path></svg></button>
        <span class="sp-time">0:00 / 0:00</span>
        <span class="sp-spacer"></span>
        <span class="sp-live">LIVE</span>
        <button class="sp-cap" type="button" aria-label="자막 위치 전환"></button>
        <button class="sp-mute" type="button" aria-label="음소거"></button>
        <button class="sp-fs" type="button" aria-label="전체화면"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9V5a1 1 0 0 1 1-1h4M20 9V5a1 1 0 0 0-1-1h-4M4 15v4a1 1 0 0 0 1 1h4M20 15v4a1 1 0 0 1-1 1h-4"/></svg></button>
      </div>
    </div>
  </div>
)}
