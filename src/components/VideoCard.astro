---
import HostMascot from './HostMascot.astro';
import { durationLabel, formatViews, timeAgo, watchHref, posterOf } from '../lib/video';
import type { CollectionEntry } from 'astro:content';

interface Props {
  video: CollectionEntry<'videos'>;
  variant?: 'grid' | 'side';
}
const { video, variant = 'grid' } = Astro.props;
const { data } = video;
const poster = posterOf(data);
const dur = durationLabel(data.scenes, data.durationLabel);
const href = watchHref(video.id);

// 썸네일에 얹는 미니 로지 — video.id 시드로 위치/크기/좌우반전/표정을 결정론적 랜덤화
// (빌드마다 동일, 카드마다 다름). expr 파일명 기준, 'idle'은 기본 얼굴(밴드 없음).
function seeded(str: string) {
  let h = 2166136261;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return () => {
    h += 0x6d2b79f5;
    let t = h;
    t = Math.imul(t ^ (t >>> 15), 1 | t);
    t ^= t + Math.imul(t ^ (t >>> 7), 61 | t);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rnd = seeded(video.id);
const rojiEmos = ['idle', 'smile', 'surprised', 'pout', 'wink', 'laugh', 'shy'];
const rojiSide = rnd() < 0.5 ? 'left' : 'right';
const rojiOff = (rnd() * 5).toFixed(1); // 가장자리 0~5%
const rojiH = (56 + rnd() * 32).toFixed(0); // 높이 56~88%
const rojiFlip = rnd() < 0.5;
const rojiEmo = rojiEmos[Math.floor(rnd() * rojiEmos.length)];
const rojiStyle = `${rojiSide}:${rojiOff}%;height:${rojiH}%;${rojiFlip ? 'transform:scaleX(-1);' : ''}`;
---

{
  variant === 'grid' ? (
    <a href={href} class="vcard">
      <div class:list={['vcard-thumb', { 'is-empty': !poster }]}>
        <div class="sp-bg is-grad is-on" style="position:absolute;inset:0"></div>
        {poster && <img src={poster} alt={data.title} loading="lazy" onerror="this.style.display='none'" />}
        <span class="card-roji" style={rojiStyle} aria-hidden="true">
          <img class="roji-base" src="/host/rosie.png" alt="" loading="lazy" />
          {rojiEmo !== 'idle' && (
            <img class="roji-face" src={`/host/expr/${rojiEmo}.png`} alt="" loading="lazy" />
          )}
        </span>
        <span class="vcard-cat">{data.category}</span>
        <span class="vcard-dur">{dur}</span>
        <span class="vcard-play">
          <span>
            <svg viewBox="0 0 24 24" width="22" height="22" fill="#fff">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </div>
      <div class="vcard-meta">
        <span class="vcard-ava">
          <HostMascot variant="avatar" />
        </span>
        <div class="vcard-info">
          <h3>{data.title}</h3>
          <div class="sub">
            <div class="ch">로지 · VIP</div>
            <div>
              {formatViews(data.views)} · {timeAgo(data.pubDate)}
            </div>
          </div>
        </div>
      </div>
    </a>
  ) : (
    <a href={href} class="side-card">
      <div class="vcard-thumb">
        <div class="sp-bg is-grad is-on" style="position:absolute;inset:0"></div>
        {poster && <img src={poster} alt={data.title} loading="lazy" onerror="this.style.display='none'" />}
        <span class="vcard-dur">{dur}</span>
      </div>
      <div>
        <h3>{data.title}</h3>
        <div class="sub">로지 · VIP</div>
        <div class="sub">
          {formatViews(data.views)} · {timeAgo(data.pubDate)}
        </div>
      </div>
    </a>
  )
}
