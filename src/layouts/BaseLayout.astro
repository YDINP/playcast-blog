---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  canonicalUrl?: string;
  ogType?: string;
  keywords?: string;
  article?: {
    published?: string;
    modified?: string;
    section?: string;
    tags?: string[];
  };
  schemas?: any[]; // 페이지별 추가 JSON-LD
}
const {
  title,
  description,
  image,
  imageAlt,
  canonicalUrl,
  ogType = 'website',
  keywords,
  article,
  schemas = [],
} = Astro.props;
const siteTitle = 'Virtual in Playing (VIP) — 게임 소개 방송 채널';
const fullTitle = title === siteTitle ? title : `${title} | VIP`;
const site = Astro.site || new URL('https://virtual-in-playing.vercel.app');
const ogImage = image || new URL('/og-default.png', site).href;
const ogImageAlt = imageAlt || title;
const canonical = canonicalUrl || Astro.url.href;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Virtual in Playing',
  alternateName: 'VIP',
  url: site.href,
  description: '버츄얼 호스트가 게임·최신작·버추얼 아이돌을 영상처럼 소개하는 채널',
  inLanguage: 'ko-KR',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: `${site.href}?q={q}` },
    'query-input': 'required name=q',
  },
};
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Virtual in Playing',
  alternateName: 'VIP',
  url: site.href,
  logo: {
    '@type': 'ImageObject',
    url: new URL('/og-default.png', site).href,
    width: 1200,
    height: 630,
  },
  description: '버츄얼 호스트 로지가 게임·최신작·버추얼 아이돌을 영상처럼 소개하는 채널',
};
const allSchemas = [websiteSchema, organizationSchema, ...schemas];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="naver-site-verification" content="c0454e4fce1924ac696fde9e9c789bc4e9abb44f" />
    <meta name="google-site-verification" content="uShjQZTfZFAauTdbCg7ZN0cvDV_ErVoVmdCScJ75TIQ" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="로지 (VIP)" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0f0f11" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="VIP RSS" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="Virtual in Playing (VIP)" />
    {article?.published && <meta property="article:published_time" content={article.published} />}
    {article?.modified && <meta property="article:modified_time" content={article.modified} />}
    {article?.section && <meta property="article:section" content={article.section} />}
    {article?.tags?.map((t) => <meta property="article:tag" content={t} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Pretendard 웹폰트 (외부 CDN preconnect로 폰트 로드 지연 완화) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <!-- Pretendard 웹폰트 -->
    <link
      rel="stylesheet"
      as="style"
      crossorigin
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    {allSchemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- Google AdSense (자동 광고) -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9400779918671270"
      crossorigin="anonymous"
      is:inline></script>
  </head>
  <body>
    <header class="pc-header">
      <div class="pc-bar">
        <a href="/" class="pc-logo">
          <span class="dot">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
          </span>
          <b>V<span>I</span>P</b>
        </a>
        <div class="pc-search">
          <svg class="pc-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path>
          </svg>
          <input
            type="search"
            id="pc-search-input"
            placeholder="게임·채널 검색"
            autocomplete="off"
            aria-label="검색"
          />
        </div>
        <nav class="pc-nav">
          <a href="/" class="hide-sm">홈</a>
          <a href="/about">채널</a>
          <a href="https://ai-revenue-blog.vercel.app/" target="_blank" rel="noopener" class="hide-sm">TechFlow ↗</a>
          <a href="https://life-revenue-blog.vercel.app/" target="_blank" rel="noopener" class="hide-sm">LifeFlow ↗</a>
          <span class="pc-onair" title="로지는 항상 방송 중입니다"><i></i>ON AIR</span>
        </nav>
      </div>
    </header>

    <main class="pc-main">
      <slot />
    </main>

    <footer class="pc-footer">
      <p class="pc-footer-family">
        함께 보기 ·
        <a href="https://ai-revenue-blog.vercel.app/" target="_blank" rel="noopener">TechFlow ↗</a> ·
        <a href="https://life-revenue-blog.vercel.app/" target="_blank" rel="noopener">LifeFlow ↗</a>
      </p>
      <p>
        © {new Date().getFullYear()} VIP · 버츄얼 호스트 로지의 게임 소개 채널 ·
        <a href="/rss.xml">RSS</a>
      </p>
    </footer>

    <script src="/js/scene-player.js" defer is:inline></script>
    <slot name="tail" />

    <!-- Pageview tracking (VIP → 공용 analytics, ai-revenue 대시보드 집계) -->
    <script is:inline>
      (function () {
        var ANALYTICS_URL = 'https://xyprbsmagtlzebxyxsvj.supabase.co/functions/v1/analytics-ingest';
        var NOTRACK_KEY = '__notrack';
        // 관리자 opt-out: ?admin=1 한 번 접속 시 이 브라우저는 이후 집계 제외 (?admin=0 해제)
        try {
          var q = new URLSearchParams(window.location.search).get('admin');
          if (q === '1') localStorage.setItem(NOTRACK_KEY, '1');
          else if (q === '0') localStorage.removeItem(NOTRACK_KEY);
        } catch (e) {}
        // 1) 로컬/사설망(dev·미리보기)은 집계 제외
        var host = window.location.hostname;
        var isLocal = host === 'localhost' || host === '127.0.0.1' || host === '::1' || host === '0.0.0.0'
          || /^192\.168\./.test(host) || /^10\./.test(host) || /^172\.(1[6-9]|2\d|3[01])\./.test(host);
        if (isLocal) return;
        // 2) 봇/헤드리스/크롤러(yeti·daumoa·google 크롤러 포함) 제외. naver/yandex/baidu 넓은 토큰 금지(인앱 실유저 오분류)
        var ua = navigator.userAgent || '';
        if (navigator.webdriver || /bot|crawl|spider|headless|lighthouse|playwright|puppeteer|slurp|petalbot|bytespider|yeti|daumoa|googleother|google-inspection/i.test(ua)) return;
        // 3) 관리자 플래그면 제외
        try { if (localStorage.getItem(NOTRACK_KEY) === '1') return; } catch (e) {}
        var slug = window.location.pathname.replace(/^\/watch\//, '').replace(/\/$/, '') || 'home';
        var qs = new URLSearchParams(window.location.search);
        fetch(ANALYTICS_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            event_type: 'pageview',
            source: 'vip',
            metadata: {
              slug: slug,
              title: document.title,
              path: window.location.pathname,
              referrer: document.referrer || 'direct',
              user_agent: navigator.userAgent,
              utm_source: qs.get('utm_source') || undefined,
              utm_medium: qs.get('utm_medium') || undefined,
              utm_campaign: qs.get('utm_campaign') || undefined
            }
          })
        }).catch(function () {});
      })();
    </script>
  </body>
</html>
